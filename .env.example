# AI Tech Blog Configuration
# Copy this file to .env and fill in values

# Database
DATABASE_URL=postgres://app:changeme@localhost:5432/ai_tech_blog

# ttoClaw Integration
TTOCLAW_NEWS_ENDPOINT=http://localhost:4000/api/news
# SLACK_WEBHOOK_URL=  # Optional: for Slack notification

# LLM (for article generation)
ANTHROPIC_API_KEY=
# or OPENAI_API_KEY=

# Server
PORT=3100
NODE_ENV=production
