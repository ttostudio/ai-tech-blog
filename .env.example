# AI Tech Blog Configuration
# Copy this file to .env and fill in values

# Database
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://app:changeme@localhost:5432/ai_tech_blog

# ttoClaw Integration
TTOCLAW_NEWS_ENDPOINT=http://localhost:4000/api/news

# LLM (for article generation)
ANTHROPIC_API_KEY=

# Ingestion Schedule (cron format, default: every 6 hours)
INGESTION_CRON=0 */6 * * *

# Logging
LOG_LEVEL=info
