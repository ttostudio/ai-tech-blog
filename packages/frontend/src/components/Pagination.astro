---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
  queryParams?: Record<string, string>;
}

const { currentPage, totalPages, baseUrl, queryParams = {} } = Astro.props;

function buildUrl(page: number): string {
  const params = new URLSearchParams({ ...queryParams, page: String(page) });
  return `${baseUrl}?${params.toString()}`;
}

function getPages(current: number, total: number): (number | '...')[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const pages: (number | '...')[] = [1];
  if (current > 3) pages.push('...');
  for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
    pages.push(i);
  }
  if (current < total - 2) pages.push('...');
  pages.push(total);
  return pages;
}

const pages = getPages(currentPage, totalPages);
---

{totalPages > 1 && (
  <nav class="pagination" aria-label="ページネーション">
    <a
      href={currentPage > 1 ? buildUrl(currentPage - 1) : undefined}
      class:list={['pagination-btn', { disabled: currentPage <= 1 }]}
      aria-label="前のページ"
      aria-disabled={currentPage <= 1 ? 'true' : 'false'}
    >
      &lsaquo; 前へ
    </a>

    {pages.map((page) =>
      page === '...' ? (
        <span class="pagination-ellipsis">…</span>
      ) : (
        <a
          href={buildUrl(page)}
          class:list={['pagination-page', { active: page === currentPage }]}
          aria-current={page === currentPage ? 'page' : undefined}
        >
          {page}
        </a>
      )
    )}

    <a
      href={currentPage < totalPages ? buildUrl(currentPage + 1) : undefined}
      class:list={['pagination-btn', { disabled: currentPage >= totalPages }]}
      aria-label="次のページ"
      aria-disabled={currentPage >= totalPages ? 'true' : 'false'}
    >
      次へ &rsaquo;
    </a>
  </nav>
)}

<style>
  .pagination {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    align-items: center;
    padding: 2rem 0;
    flex-wrap: wrap;
  }

  .pagination-btn,
  .pagination-page {
    padding: 0.5rem 0.875rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    background: var(--color-card-bg);
    border: 1px solid var(--color-card-border);
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    user-select: none;
  }

  .pagination-btn:hover:not(.disabled),
  .pagination-page:hover:not(.active) {
    color: var(--color-accent);
    border-color: rgba(34, 211, 238, 0.3);
    background: var(--color-bg-tertiary);
    text-decoration: none;
  }

  .pagination-page.active {
    background: linear-gradient(135deg, var(--color-gradient-start), var(--color-gradient-end));
    color: #fff;
    border-color: transparent;
    font-weight: 700;
  }

  .pagination-btn.disabled {
    opacity: 0.3;
    pointer-events: none;
    cursor: not-allowed;
  }

  .pagination-ellipsis {
    padding: 0.5rem 0.25rem;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }
</style>
