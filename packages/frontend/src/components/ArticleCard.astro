---
interface Props {
  title: string;
  slug: string;
  excerpt: string;
  category: string;
  tags: string[];
  author: string;
  publishedAt: string | null;
}

const { title, slug, excerpt, category, tags, author, publishedAt } = Astro.props;

const dateStr = publishedAt
  ? new Date(publishedAt).toLocaleDateString('ja-JP', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';
---

<article class="article-card">
  <a href={`/articles/${slug}`}>
    <div class="card-meta">
      <span class="category">{category}</span>
      <span class="author">{author}</span>
      {dateStr && <time>{dateStr}</time>}
    </div>
    <h2>{title}</h2>
    <p>{excerpt}</p>
    {tags.length > 0 && (
      <div class="tags">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </a>
</article>

<style>
  .article-card {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    background: var(--color-card-bg);
    transition: border-color 0.2s;
  }

  .article-card:hover {
    border-color: var(--color-accent);
  }

  .article-card a {
    color: inherit;
    text-decoration: none;
  }

  .card-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .category {
    background: var(--color-bg-secondary);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-weight: 500;
  }

  .author {
    font-style: italic;
  }

  h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  p {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8rem;
    color: var(--color-accent);
    background: var(--color-bg-secondary);
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
  }
</style>
