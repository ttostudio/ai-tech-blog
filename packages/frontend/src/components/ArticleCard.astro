---
interface Props {
  title: string;
  slug: string;
  excerpt: string;
  category: string;
  tags: string[];
  author: string;
  publishedAt: string | null;
  thumbnailUrl?: string | null;
}

const { title, slug, excerpt, category, tags, author, publishedAt, thumbnailUrl } = Astro.props;

const dateStr = publishedAt
  ? new Date(publishedAt).toLocaleDateString('ja-JP', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';

const CATEGORY_GRADIENTS: Record<string, string> = {
  'claude-code': 'linear-gradient(135deg, #667eea, #764ba2)',
  'ai-hacks': 'linear-gradient(135deg, #f093fb, #f5576c)',
  'ai-news': 'linear-gradient(135deg, #4facfe, #00f2fe)',
  'tech': 'linear-gradient(135deg, #43e97b, #38f9d7)',
};

const fallbackGradient = CATEGORY_GRADIENTS[category] ?? 'linear-gradient(135deg, #667eea, #764ba2)';
---

<article class="article-card">
  <a href={`/articles/${slug}`}>
    <div class="card-layout">
      <div class="thumbnail-wrapper">
        {thumbnailUrl ? (
          <div class="thumbnail-skeleton" aria-hidden="true"></div>
          <img
            src={thumbnailUrl}
            alt={title}
            width="1024"
            height="576"
            loading="lazy"
            decoding="async"
            class="thumbnail"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
          />
          <div class="thumbnail-fallback" style={`background: ${fallbackGradient}`}>
            <span class="fallback-label">{category}</span>
          </div>
        ) : (
          <div class="thumbnail-fallback visible" style={`background: ${fallbackGradient}`}>
            <span class="fallback-label">{category}</span>
          </div>
        )}
      </div>
      <div class="card-body">
        <div class="card-meta">
          <span class="category">{category}</span>
          <span class="author">{author}</span>
          {dateStr && <time>{dateStr}</time>}
        </div>
        <h2>{title}</h2>
        <p>{excerpt}</p>
        {tags.length > 0 && (
          <div class="tags">
            {tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .article-card {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-card-bg);
    transition: border-color 0.2s;
    overflow: hidden;
  }

  .article-card:hover {
    border-color: var(--color-accent);
  }

  .article-card a {
    color: inherit;
    text-decoration: none;
  }

  .card-layout {
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 600px) {
    .card-layout {
      flex-direction: row;
    }

    .thumbnail-wrapper {
      width: 200px;
      flex-shrink: 0;
    }
  }

  .thumbnail-wrapper {
    position: relative;
    aspect-ratio: var(--thumbnail-ratio);
    overflow: hidden;
  }

  @media (min-width: 600px) {
    .thumbnail-wrapper {
      aspect-ratio: auto;
    }
  }

  .thumbnail-skeleton {
    position: absolute;
    inset: 0;
    background: var(--thumbnail-skeleton-bg);
    animation: skeleton-pulse 1.5s ease-in-out infinite;
  }

  .thumbnail {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .thumbnail-fallback {
    display: none;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
  }

  .thumbnail-fallback.visible {
    display: flex;
    position: relative;
    aspect-ratio: var(--thumbnail-ratio);
  }

  @media (min-width: 600px) {
    .thumbnail-fallback.visible {
      aspect-ratio: auto;
      position: absolute;
      inset: 0;
    }

    .thumbnail-wrapper:has(.thumbnail-fallback.visible) {
      position: relative;
    }
  }

  .fallback-label {
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
  }

  .card-body {
    padding: 1.25rem;
  }

  .card-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .category {
    background: var(--color-bg-secondary);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-weight: 500;
  }

  .author {
    font-style: italic;
  }

  h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  p {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8rem;
    color: var(--color-accent);
    background: var(--color-bg-secondary);
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
  }
</style>
