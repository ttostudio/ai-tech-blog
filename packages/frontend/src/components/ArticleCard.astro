---
interface Props {
  title: string;
  slug: string;
  excerpt: string;
  category: string;
  tags: string[];
  author: string;
  publishedAt: string | null;
  thumbnailUrl?: string | null;
  featured?: boolean;
}

const { title, slug, excerpt, category, tags, author, publishedAt, thumbnailUrl, featured = false } = Astro.props;

const dateStr = publishedAt
  ? new Date(publishedAt).toLocaleDateString('ja-JP', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';

// カテゴリ別グラデーション
const CATEGORY_GRADIENTS: Record<string, string> = {
  'claude-code': 'linear-gradient(135deg, #22d3ee 0%, #818cf8 100%)',
  'ai-hacks': 'linear-gradient(135deg, #34d399 0%, #22d3ee 100%)',
  'ai-news': 'linear-gradient(135deg, #f472b6 0%, #818cf8 100%)',
  'tech': 'linear-gradient(135deg, #fb923c 0%, #f472b6 100%)',
};

const coverGradient = CATEGORY_GRADIENTS[category] ?? 'linear-gradient(135deg, #22d3ee 0%, #818cf8 100%)';

// カテゴリ表示名
const CATEGORY_LABELS: Record<string, string> = {
  'claude-code': 'Claude Code',
  'ai-hacks': 'AI Hacks',
  'ai-news': 'AI News',
  'tech': 'Tech',
};
const categoryLabel = CATEGORY_LABELS[category] ?? category;
---

<article class:list={['article-card', { featured }]}>
  <a href={`/articles/${slug}`}>
    {/* カバービジュアル: サムネイルがあれば画像、なければグラデーション */}
    {thumbnailUrl ? (
      <div class="card-cover card-cover--thumbnail">
        <div class="thumbnail-skeleton" aria-hidden="true"></div>
        <img
          src={thumbnailUrl}
          alt={title}
          width="1024"
          height="576"
          loading="lazy"
          decoding="async"
          class="thumbnail"
          onerror="this.style.display='none'; this.parentElement.style.background=this.parentElement.dataset.fallback"
        />
        <div class="card-cover" style={`background: ${coverGradient}; display: none;`} data-fallback-cover>
          <span class="cover-label">{categoryLabel}</span>
        </div>
      </div>
    ) : (
      <div class="card-cover" style={`background: ${coverGradient}`}>
        <span class="cover-label">{categoryLabel}</span>
      </div>
    )}
    <div class="card-content">
      <div class="card-meta">
        <span class="category-badge">{category}</span>
        {dateStr && <time>{dateStr}</time>}
      </div>
      <h2 class="card-title">{title}</h2>
      <p class="card-excerpt">{excerpt}</p>
      <div class="card-footer">
        <span class="author-info">
          <span class="author-avatar">{author.charAt(0).toUpperCase()}</span>
          <span class="author-name">{author}</span>
        </span>
        {tags.length > 0 && (
          <div class="tags">
            {tags.slice(0, 3).map((tag) => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  @keyframes fade-slide-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .article-card {
    background: var(--color-card-bg);
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
    box-shadow: var(--shadow-card);
    opacity: 0;
    animation: fade-slide-up 0.5s ease forwards;
    animation-delay: calc(var(--i, 0) * 0.1s);
  }

  .article-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
    border-color: rgba(34, 211, 238, 0.2);
  }

  .article-card a {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  /* カバービジュアル */
  .card-cover {
    height: 160px;
    display: flex;
    align-items: flex-end;
    padding: var(--space-3) var(--space-4);
    position: relative;
    overflow: hidden;
  }

  .card-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.35) 100%);
  }

  /* Thumbnail cover variant */
  .card-cover--thumbnail {
    padding: 0;
    height: 180px;
  }

  .card-cover--thumbnail::after {
    display: none;
  }

  .thumbnail-skeleton {
    position: absolute;
    inset: 0;
    background: var(--thumbnail-skeleton-bg);
    animation: skeleton-pulse 1.5s ease-in-out infinite;
  }

  .thumbnail {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 1;
  }

  .cover-label {
    position: relative;
    z-index: 1;
    font-size: var(--text-xs);
    font-weight: 700;
    color: rgba(255, 255, 255, 0.9);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .card-content {
    padding: var(--space-5);
  }

  .card-meta {
    display: flex;
    gap: var(--space-3);
    align-items: center;
    margin-bottom: var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .category-badge {
    background: var(--color-badge-bg);
    color: var(--color-badge-text);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.02em;
  }

  .card-title {
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: var(--space-2);
    line-height: 1.4;
    color: var(--color-text);
    transition: color var(--transition-base);
  }

  .article-card:hover .card-title {
    background: linear-gradient(135deg, var(--color-gradient-start), var(--color-gradient-end));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card-excerpt {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .author-info {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .author-avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-gradient-start), var(--color-gradient-end));
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .author-name {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.7rem;
    color: var(--color-accent);
    opacity: 0.7;
  }

  /* Featured card variant */
  .featured .card-cover {
    height: 200px;
  }

  .featured .card-cover--thumbnail {
    height: 240px;
  }

  .featured .card-content {
    padding: var(--space-8);
  }

  .featured .card-title {
    font-size: var(--text-2xl);
    background: linear-gradient(135deg, var(--color-gradient-start), var(--color-gradient-end));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .featured .card-excerpt {
    -webkit-line-clamp: 3;
    font-size: var(--text-base);
  }

  @media (max-width: 768px) {
    .card-cover {
      height: 120px;
    }

    .card-cover--thumbnail {
      height: 140px;
    }

    .featured .card-cover {
      height: 140px;
    }

    .featured .card-cover--thumbnail {
      height: 160px;
    }

    .card-content {
      padding: var(--space-5);
    }

    .card-title {
      font-size: var(--text-lg);
    }

    .featured .card-content {
      padding: var(--space-6);
    }

    .featured .card-title {
      font-size: var(--text-xl);
    }
  }
</style>
