---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { fetchApi } from '../../lib/api';

interface ArticleSummary {
  id: string;
  title: string;
  slug: string;
  excerpt: string;
  category: string;
  tags: string[];
  author: string;
  publishedAt: string | null;
}

interface ApiResponse {
  data: ArticleSummary[];
  pagination: { page: number; limit: number; total: number; totalPages: number };
}

const CATEGORY_LABELS: Record<string, string> = {
  'claude-code': 'Claude Codeニュース',
  'ai-hacks': 'AIハック＆トレンド',
  'ai-news': 'AIニュース',
  'tech': 'テクノロジー',
};

const { name } = Astro.params;
const displayName = CATEGORY_LABELS[name ?? ''] ?? name ?? '';
let articles: ArticleSummary[] = [];

try {
  const res = await fetchApi<ApiResponse>(`/articles?status=published&category=${name}&limit=50`);
  articles = res.data;
} catch (e) {
  console.error(e);
}
---

<BaseLayout title={displayName}>
  <section class="category-header">
    <h1 class="category-title"><span class="gradient-text">{displayName}</span></h1>
    <p class="category-count">{articles.length} 件の記事</p>
  </section>

  <section class="article-grid-section">
    {articles.length === 0 && (
      <div class="empty">
        <p>このカテゴリにはまだ記事がありません。</p>
        <a href="/" class="back-link">&larr; ホームに戻る</a>
      </div>
    )}
    <div class="article-grid">
      {articles.map((article) => (
        <ArticleCard
          title={article.title}
          slug={article.slug}
          excerpt={article.excerpt}
          category={article.category}
          tags={article.tags}
          author={article.author}
          publishedAt={article.publishedAt}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .category-header {
    padding: 2rem 0 2.5rem;
    text-align: center;
  }

  .category-title {
    font-size: 2rem;
    font-weight: 900;
    margin-bottom: 0.5rem;
  }

  .category-count {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .empty {
    text-align: center;
    color: var(--color-text-secondary);
    padding: 4rem 0;
  }

  .empty .back-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--color-accent);
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .category-title {
      font-size: 1.5rem;
    }

    .article-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
