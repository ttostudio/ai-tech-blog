---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Pagination from '../components/Pagination.astro';
import { fetchApi } from '../lib/api';

interface ArticleSummary {
  id: string;
  title: string;
  slug: string;
  excerpt: string;
  category: string;
  tags: string[];
  author: string;
  publishedAt: string | null;
  thumbnailUrl?: string | null;
  contentLength?: number | null;
}

interface ApiResponse {
  data: ArticleSummary[];
  pagination: { page: number; limit: number; total: number; totalPages: number };
}

interface Category {
  name: string;
  displayName: string;
  articleCount: number;
}

interface CategoriesResponse {
  data: Category[];
}

// SSR: クエリパラメータからページ・カテゴリ・検索ワードを取得（NaNガード）
const pageParam = Astro.url.searchParams.get('page') ?? '1';
const page = Math.max(1, parseInt(pageParam) || 1);
const selectedCategory = Astro.url.searchParams.get('category') ?? undefined;
const searchQuery = Astro.url.searchParams.get('q') ?? '';

const LIMIT = 12;

let articles: ArticleSummary[] = [];
let pagination = { page: 1, limit: LIMIT, total: 0, totalPages: 1 };
let categories: Category[] = [];
let articlesError = '';

// 記事一覧取得
try {
  const params = new URLSearchParams({
    status: 'published',
    page: String(page),
    limit: String(LIMIT),
  });
  if (selectedCategory) params.set('category', selectedCategory);
  if (searchQuery) params.set('q', searchQuery);

  const res = await fetchApi<ApiResponse>(`/articles?${params.toString()}`);
  articles = res.data;
  pagination = res.pagination;
} catch (e) {
  articlesError = '記事の読み込みに失敗しました。しばらく経ってから再度お試しください。';
  console.error(e);
}

// カテゴリ一覧取得（失敗しても記事一覧は表示継続）
try {
  const res = await fetchApi<CategoriesResponse>('/categories');
  categories = res.data;
} catch (e) {
  console.error('カテゴリ取得失敗:', e);
}

const featuredArticle = articles[0] ?? null;
const restArticles = articles.slice(1);

// ページネーション用の追加クエリパラメータ
const paginationParams: Record<string, string> = {};
if (selectedCategory) paginationParams.category = selectedCategory;
if (searchQuery) paginationParams.q = searchQuery;
---

<BaseLayout
  title="ホーム"
  description="AI Tech Blog — AIニュースと技術情報を自動的にお届けするttoStudioのブログ"
  ogTitle="AI Tech Blog — ttoStudio"
  ogDescription="AIニュースと技術情報を自動的にお届けするttoStudioのブログ"
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'AI Tech Blog',
      url: `${Astro.url.origin}/`,
      description: 'AIニュースと技術情報を自動的にお届けするttoStudioのブログ',
      publisher: {
        '@type': 'Organization',
        name: 'ttoStudio',
      },
    }).replace(/<\//g, '<\\/')}
  />
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-title">
        <span class="gradient-text">AI Tech Blog</span>
      </h1>
      <p class="hero-subtitle">AIニュースと技術情報を自動的にブログ記事にお届け</p>
      <div class="hero-badges">
        <span class="hero-badge">Claude Code</span>
        <span class="hero-badge">AI自動生成</span>
        <span class="hero-badge">テック記事</span>
      </div>
    </div>
  </section>

  {/* エラー状態 (F-07) */}
  {articlesError && (
    <div class="error-state">
      <span class="error-icon">⚠</span>
      <p>{articlesError}</p>
    </div>
  )}

  {/* 検索バー + カテゴリタブ */}
  {!articlesError && (
    <div class="search-filter-section">
      <div class="search-bar">
        <span class="search-icon" aria-hidden="true">&#x1F50D;</span>
        <input
          id="search-input"
          type="search"
          placeholder="記事を検索..."
          value={searchQuery}
          aria-label="記事を検索"
          autocomplete="off"
        />
      </div>
      {categories.length > 0 && (
        <div class="category-tabs" role="tablist" aria-label="カテゴリフィルタ">
          <button
            class:list={['tab-btn', { active: !selectedCategory }]}
            data-category-tab=""
            role="tab"
            aria-selected={!selectedCategory}
          >すべて</button>
          {categories.map((cat) => (
            <button
              class:list={['tab-btn', { active: selectedCategory === cat.name }]}
              data-category-tab={cat.name}
              role="tab"
              aria-selected={selectedCategory === cat.name}
            >
              {cat.displayName}
              <span class="tab-count">{cat.articleCount}</span>
            </button>
          ))}
        </div>
      )}
    </div>
  )}

  {!articlesError && articles.length === 0 && (
    <div class="empty-state">
      <div class="empty-icon">&#x1F4DD;</div>
      <h2>まだ記事がありません</h2>
      <p>エージェントが記事を投稿すると、ここに表示されます。</p>
      <code class="empty-hint">POST /api/articles で記事を投稿できます</code>
    </div>
  )}

  {featuredArticle && (
    <section class="featured-section">
      <h2 class="section-title">最新の記事</h2>
      <div style="--i: 0">
        <ArticleCard
          title={featuredArticle.title}
          slug={featuredArticle.slug}
          excerpt={featuredArticle.excerpt}
          category={featuredArticle.category}
          tags={featuredArticle.tags}
          author={featuredArticle.author}
          publishedAt={featuredArticle.publishedAt}
          thumbnailUrl={featuredArticle.thumbnailUrl}
          contentLength={featuredArticle.contentLength}
          featured={true}
        />
      </div>
    </section>
  )}

  {restArticles.length > 0 && (
    <section class="articles-section">
      <h2 class="section-title">記事一覧</h2>
      <div class="article-grid">
        {restArticles.map((article, index) => (
          <div style={`--i: ${index + 1}`}>
            <ArticleCard
              title={article.title}
              slug={article.slug}
              excerpt={article.excerpt}
              category={article.category}
              tags={article.tags}
              author={article.author}
              publishedAt={article.publishedAt}
              thumbnailUrl={article.thumbnailUrl}
              contentLength={article.contentLength}
            />
          </div>
        ))}
      </div>
    </section>
  )}

  {/* ページネーション (F-01) */}
  {!articlesError && pagination.totalPages > 1 && (
    <Pagination
      currentPage={pagination.page}
      totalPages={pagination.totalPages}
      baseUrl="/"
      queryParams={paginationParams}
    />
  )}
</BaseLayout>

<script>
  (() => {
    const LIMIT = 12;
    let currentCategory = new URLSearchParams(location.search).get('category') || '';
    let currentQ = new URLSearchParams(location.search).get('q') || '';
    let debounceTimer: ReturnType<typeof setTimeout>;

    function escHtml(str: string): string {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function formatDate(str: string | null): string {
      if (!str) return '';
      return new Date(str).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
    }

    interface ArticleItem {
      slug: string;
      title: string;
      excerpt: string;
      category: string;
      tags: string[];
      author: string;
      publishedAt: string | null;
      thumbnailUrl?: string | null;
      contentLength?: number | null;
    }

    const CATEGORY_GRADIENTS: Record<string, string> = {
      'claude-code': 'linear-gradient(135deg, #22d3ee 0%, #818cf8 100%)',
      'ai-hacks': 'linear-gradient(135deg, #34d399 0%, #22d3ee 100%)',
      'ai-news': 'linear-gradient(135deg, #f472b6 0%, #818cf8 100%)',
      'tech': 'linear-gradient(135deg, #fb923c 0%, #f472b6 100%)',
    };

    const CATEGORY_LABELS: Record<string, string> = {
      'claude-code': 'Claude Code',
      'ai-hacks': 'AI Hacks',
      'ai-news': 'AI News',
      'tech': 'Tech',
    };

    function renderCard(article: ArticleItem, index: number): string {
      const date = formatDate(article.publishedAt);
      const rt = article.contentLength ? Math.ceil(article.contentLength / 400) : null;
      const label = escHtml(CATEGORY_LABELS[article.category] || article.category);
      const gradient = CATEGORY_GRADIENTS[article.category] || 'linear-gradient(135deg, #22d3ee 0%, #818cf8 100%)';
      const tagsHtml = article.tags
        .slice(0, 3)
        .map((t) => `<span class="tag">#${escHtml(t)}</span>`)
        .join('');
      const cover = article.thumbnailUrl
        ? `<div class="card-cover card-cover--thumbnail"><div class="thumbnail-skeleton" aria-hidden="true"></div><img src="${escHtml(article.thumbnailUrl)}" alt="${escHtml(article.title)}" width="1024" height="576" loading="lazy" decoding="async" class="thumbnail" onerror="this.style.display='none'"/></div>`
        : `<div class="card-cover" style="background:${gradient}"><span class="cover-label">${label}</span></div>`;

      return `<div style="--i:${index}">
        <article class="article-card" style="opacity:0;animation:fade-slide-up 0.5s ease forwards;animation-delay:calc(${index}*0.1s)">
          <a href="/articles/${escHtml(article.slug)}">
            ${cover}
            <div class="card-content">
              <div class="card-meta">
                <span class="category-badge">${escHtml(article.category)}</span>
                ${date ? `<time>${escHtml(date)}</time>` : ''}
                ${rt ? `<span class="reading-time">約${rt}分</span>` : ''}
              </div>
              <h2 class="card-title">${escHtml(article.title)}</h2>
              <p class="card-excerpt">${escHtml(article.excerpt)}</p>
              <div class="card-footer">
                <span class="author-info">
                  <span class="author-avatar">${escHtml(article.author.charAt(0).toUpperCase())}</span>
                  <span class="author-name">${escHtml(article.author)}</span>
                </span>
                ${tagsHtml ? `<div class="tags">${tagsHtml}</div>` : ''}
              </div>
            </div>
          </a>
        </article>
      </div>`;
    }

    async function fetchAndRender(): Promise<void> {
      const params = new URLSearchParams({ status: 'published', limit: String(LIMIT) });
      if (currentCategory) params.set('category', currentCategory);
      if (currentQ) params.set('q', currentQ);

      const featuredSection = document.querySelector<HTMLElement>('.featured-section');
      const articlesSection = document.querySelector<HTMLElement>('.articles-section');
      const emptyState = document.querySelector<HTMLElement>('.empty-state');

      try {
        const res = await fetch(`/api/articles?${params.toString()}`);
        const json = await res.json() as { data: ArticleItem[] };
        const items = json.data || [];

        // URL を更新（履歴に積む）
        const url = new URL(location.href);
        url.searchParams.set('page', '1');
        if (currentCategory) url.searchParams.set('category', currentCategory);
        else url.searchParams.delete('category');
        if (currentQ) url.searchParams.set('q', currentQ);
        else url.searchParams.delete('q');
        history.pushState({}, '', url.toString());

        if (items.length === 0) {
          if (featuredSection) featuredSection.innerHTML = '';
          if (articlesSection) articlesSection.innerHTML = '';
          if (emptyState) emptyState.style.display = '';
          return;
        }
        if (emptyState) emptyState.style.display = 'none';

        const [featured, ...rest] = items;
        if (featuredSection) {
          featuredSection.innerHTML = `<h2 class="section-title">最新の記事</h2>${renderCard(featured, 0)}`;
        }
        if (articlesSection) {
          if (rest.length > 0) {
            const cardsHtml = rest.map((a, i) => renderCard(a, i + 1)).join('');
            articlesSection.innerHTML = `<h2 class="section-title">記事一覧</h2><div class="article-grid">${cardsHtml}</div>`;
          } else {
            articlesSection.innerHTML = '';
          }
        }
      } catch (e) {
        console.error('記事取得エラー:', e);
      }
    }

    // 検索入力（デバウンス 400ms）
    const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
          currentQ = (e.target as HTMLInputElement).value.trim();
          fetchAndRender();
        }, 400);
      });
    }

    // カテゴリタブ
    document.querySelectorAll<HTMLButtonElement>('[data-category-tab]').forEach((btn) => {
      btn.addEventListener('click', () => {
        currentCategory = btn.dataset.categoryTab ?? '';
        document.querySelectorAll('[data-category-tab]').forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        fetchAndRender();
      });
    });
  })();
</script>

<style>
  @keyframes gradient-shift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Hero */
  .hero {
    text-align: center;
    padding: 3rem 0 2.5rem;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-gradient-start) 8%, var(--color-bg)),
      color-mix(in srgb, var(--color-gradient-end) 8%, var(--color-bg)),
      color-mix(in srgb, var(--color-gradient-start) 8%, var(--color-bg))
    );
    background-size: 200% 200%;
    animation: gradient-shift 8s ease infinite;
    border-radius: var(--radius-lg);
    margin-bottom: 2rem;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 900;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
  }

  .hero-badges {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-badge {
    background: var(--color-badge-bg);
    color: var(--color-badge-text);
    padding: 0.35rem 1rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    border: 1px solid rgba(34, 211, 238, 0.15);
  }

  /* 検索バー + カテゴリタブ */
  .search-filter-section {
    margin-bottom: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .search-bar {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: 0.9rem;
    font-size: 0.95rem;
    pointer-events: none;
    color: var(--color-text-secondary);
  }

  #search-input {
    width: 100%;
    padding: 0.65rem 1rem 0.65rem 2.5rem;
    background: var(--color-card-bg);
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-size: 0.95rem;
    outline: none;
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  #search-input:focus {
    border-color: rgba(34, 211, 238, 0.4);
    box-shadow: 0 0 0 3px rgba(34, 211, 238, 0.1);
  }

  #search-input::placeholder {
    color: var(--color-text-secondary);
    opacity: 0.6;
  }

  .category-tabs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tab-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--color-card-border);
    background: var(--color-card-bg);
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: background var(--transition-base), color var(--transition-base), border-color var(--transition-base);
  }

  .tab-btn:hover {
    border-color: rgba(34, 211, 238, 0.3);
    color: var(--color-text);
  }

  .tab-btn.active {
    background: linear-gradient(135deg, var(--color-gradient-start), var(--color-gradient-end));
    border-color: transparent;
    color: #fff;
    font-weight: 600;
  }

  .tab-count {
    font-size: 0.75rem;
    opacity: 0.75;
  }

  /* Sections */
  .section-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    padding-left: 0.75rem;
    border-left: 3px solid var(--color-accent);
  }

  .featured-section {
    margin-bottom: 3rem;
  }

  .articles-section {
    margin-bottom: 2rem;
  }

  /* Grid: 3列(デスクトップ) / 2列(タブレット) / 1列(モバイル) */
  .article-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 1024px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Error State (F-07) */
  .error-state {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: var(--radius-md);
    color: #ef4444;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .error-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 5rem 1rem;
    color: var(--color-text-secondary);
  }

  .empty-icon {
    font-size: 3.5rem;
    margin-bottom: 1.25rem;
  }

  .empty-state h2 {
    font-size: 1.25rem;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .empty-hint {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 0.85rem;
    padding: 0.35rem 1rem;
    border-radius: var(--radius-sm);
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 0.95rem;
    }

    .article-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 1.75rem;
    }
  }
</style>
