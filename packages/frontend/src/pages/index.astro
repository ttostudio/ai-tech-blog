---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { fetchApi } from '../lib/api';

interface ArticleSummary {
  id: string;
  title: string;
  slug: string;
  excerpt: string;
  category: string;
  tags: string[];
  author: string;
  publishedAt: string | null;
}

interface ApiResponse {
  data: ArticleSummary[];
  pagination: { page: number; limit: number; total: number; totalPages: number };
}

let articles: ArticleSummary[] = [];
let error = '';

try {
  const res = await fetchApi<ApiResponse>('/articles?status=published&limit=20');
  articles = res.data;
} catch (e) {
  error = '記事の読み込みに失敗しました';
  console.error(e);
}

const featuredArticle = articles[0] ?? null;
const restArticles = articles.slice(1);
---

<BaseLayout title="ホーム">
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-title">
        <span class="gradient-text">AI Tech Blog</span>
      </h1>
      <p class="hero-subtitle">AIニュースと技術情報を自動的にブログ記事にお届け</p>
      <div class="hero-badges">
        <span class="hero-badge">Claude Code</span>
        <span class="hero-badge">AI自動生成</span>
        <span class="hero-badge">テック記事</span>
      </div>
    </div>
  </section>

  {error && <p class="error">{error}</p>}

  {articles.length === 0 && !error && (
    <div class="empty-state">
      <div class="empty-icon">&#x1F4DD;</div>
      <h2>まだ記事がありません</h2>
      <p>エージェントが記事を投稿すると、ここに表示されます。</p>
      <code class="empty-hint">POST /api/articles で記事を投稿できます</code>
    </div>
  )}

  {featuredArticle && (
    <section class="featured-section">
      <h2 class="section-title">最新の記事</h2>
      <div style="--i: 0">
        <ArticleCard
          title={featuredArticle.title}
          slug={featuredArticle.slug}
          excerpt={featuredArticle.excerpt}
          category={featuredArticle.category}
          tags={featuredArticle.tags}
          author={featuredArticle.author}
          publishedAt={featuredArticle.publishedAt}
          featured={true}
        />
      </div>
    </section>
  )}

  {restArticles.length > 0 && (
    <section class="articles-section">
      <h2 class="section-title">記事一覧</h2>
      <div class="article-grid">
        {restArticles.map((article, index) => (
          <div style={`--i: ${index + 1}`}>
            <ArticleCard
              title={article.title}
              slug={article.slug}
              excerpt={article.excerpt}
              category={article.category}
              tags={article.tags}
              author={article.author}
              publishedAt={article.publishedAt}
            />
          </div>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  @keyframes gradient-shift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Hero */
  .hero {
    text-align: center;
    padding: 3rem 0 2.5rem;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-gradient-start) 8%, var(--color-bg)),
      color-mix(in srgb, var(--color-gradient-end) 8%, var(--color-bg)),
      color-mix(in srgb, var(--color-gradient-start) 8%, var(--color-bg))
    );
    background-size: 200% 200%;
    animation: gradient-shift 8s ease infinite;
    border-radius: var(--radius-lg);
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 900;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
  }

  .hero-badges {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-badge {
    background: var(--color-badge-bg);
    color: var(--color-badge-text);
    padding: 0.35rem 1rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    border: 1px solid rgba(34, 211, 238, 0.15);
  }

  /* Sections */
  .section-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    padding-left: 0.75rem;
    border-left: 3px solid var(--color-accent);
  }

  .featured-section {
    margin-bottom: 3rem;
  }

  .articles-section {
    margin-bottom: 2rem;
  }

  /* Grid */
  .article-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 5rem 1rem;
    color: var(--color-text-secondary);
  }

  .empty-icon {
    font-size: 3.5rem;
    margin-bottom: 1.25rem;
  }

  .empty-state h2 {
    font-size: 1.25rem;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .empty-hint {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 0.85rem;
    padding: 0.35rem 1rem;
    border-radius: var(--radius-sm);
  }

  .error {
    text-align: center;
    color: #ef4444;
    padding: 3rem 0;
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 0.95rem;
    }

    .article-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
