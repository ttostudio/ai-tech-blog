---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { fetchApi } from '../lib/api';

interface ArticleSummary {
  id: string;
  title: string;
  slug: string;
  excerpt: string;
  category: string;
  tags: string[];
  publishedAt: string | null;
}

interface ApiResponse {
  data: ArticleSummary[];
  pagination: { page: number; limit: number; total: number; totalPages: number };
}

let articles: ArticleSummary[] = [];
let error = '';

try {
  const res = await fetchApi<ApiResponse>('/articles?status=published&limit=20');
  articles = res.data;
} catch (e) {
  error = 'Failed to load articles';
  console.error(e);
}
---

<BaseLayout title="Home">
  <section class="hero">
    <h1>AI Tech Blog</h1>
    <p>AIニュースと技術情報を自動的にブログ記事にお届け</p>
  </section>

  {error && <p class="error">{error}</p>}

  <section class="article-list">
    {articles.length === 0 && !error && (
      <p class="empty">記事はまだありません。ttoClaw がニュースを収集するとここに表示されます。</p>
    )}
    {articles.map((article) => (
      <ArticleCard
        title={article.title}
        slug={article.slug}
        excerpt={article.excerpt}
        category={article.category}
        tags={article.tags}
        publishedAt={article.publishedAt}
      />
    ))}
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 2rem 0 3rem;
  }

  .hero h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .hero p {
    color: var(--color-text-secondary);
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .empty, .error {
    text-align: center;
    color: var(--color-text-secondary);
    padding: 3rem 0;
  }

  .error {
    color: #ef4444;
  }
</style>
