---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { fetchApi } from '../lib/api';

interface ArticleSummary {
  id: string;
  title: string;
  slug: string;
  excerpt: string;
  category: string;
  tags: string[];
  author: string;
  publishedAt: string | null;
}

interface ApiResponse {
  data: ArticleSummary[];
  pagination: { page: number; limit: number; total: number; totalPages: number };
}

let articles: ArticleSummary[] = [];
let error = '';

try {
  const res = await fetchApi<ApiResponse>('/articles?status=published&limit=20');
  articles = res.data;
} catch (e) {
  error = 'Failed to load articles';
  console.error(e);
}
---

<BaseLayout title="Home">
  <section class="hero">
    <h1>AI Tech Blog</h1>
    <p>AIニュースと技術情報を自動的にブログ記事にお届け</p>
  </section>

  {error && <p class="error">{error}</p>}

  <section class="article-list">
    {articles.length === 0 && !error && (
      <div class="empty-state">
        <p class="empty-icon">&#x1f4dd;</p>
        <h2>まだ記事がありません</h2>
        <p>エージェントが記事を投稿すると、ここに表示されます。</p>
        <p class="empty-hint">POST /api/articles で記事を投稿できます。</p>
      </div>
    )}
    {articles.map((article) => (
      <ArticleCard
        title={article.title}
        slug={article.slug}
        excerpt={article.excerpt}
        category={article.category}
        tags={article.tags}
        author={article.author}
        publishedAt={article.publishedAt}
      />
    ))}
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 2rem 0 3rem;
  }

  .hero h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .hero p {
    color: var(--color-text-secondary);
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--color-text-secondary);
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .empty-state h2 {
    font-size: 1.25rem;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .empty-hint {
    margin-top: 1rem;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    background: var(--color-bg-secondary);
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
  }

  .error {
    text-align: center;
    color: #ef4444;
    padding: 3rem 0;
  }
</style>
