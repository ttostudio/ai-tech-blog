---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { fetchApi } from '../../lib/api';
import { marked } from 'marked';

interface ArticleData {
  id: string;
  title: string;
  slug: string;
  content: string;
  excerpt: string;
  category: string;
  tags: string[];
  author: string;
  status: string;
  publishedAt: string | null;
  createdAt: string;
}

interface ArticleSummary {
  id: string;
  title: string;
  slug: string;
  publishedAt: string | null;
  category: string;
}

const { slug } = Astro.params;
let article: ArticleData | null = null;

try {
  const res = await fetchApi<{ data: ArticleData }>(`/articles/${slug}`);
  article = res.data;
} catch {
  return Astro.redirect('/404');
}

// Markdown → HTML
const rawHtml = article ? await marked.parse(article.content) : '';

// 見出しにIDを付与してTOC用に抽出 (F-04)
const headingCounts: Record<string, number> = {};

function generateId(text: string): string {
  const base = text
    .toLowerCase()
    .replace(/<[^>]+>/g, '')
    .replace(/[^\w\s\u3040-\u309F\u30A0-\u30FF\u4E00-\u9FFF-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .trim();
  const count = headingCounts[base] ?? 0;
  headingCounts[base] = count + 1;
  return count === 0 ? base : `${base}-${count}`;
}

interface HeadingItem {
  level: 2 | 3;
  id: string;
  text: string;
}

const headings: HeadingItem[] = [];

const htmlContent = rawHtml.replace(/<h([23])([^>]*)>([\s\S]*?)<\/h\1>/gi, (_match, level, attrs, inner) => {
  const text = inner.replace(/<[^>]+>/g, '');
  const id = generateId(text);
  headings.push({ level: parseInt(level) as 2 | 3, id, text });
  return `<h${level}${attrs} id="${id}">${inner}</h${level}>`;
});

const dateStr = article?.publishedAt
  ? new Date(article.publishedAt).toLocaleDateString('ja-JP', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';
const readingTime = article ? Math.max(1, Math.ceil(article.content.length / 500)) : 1;

// 前後記事取得 (F-08)
let prevArticle: ArticleSummary | null = null;
let nextArticle: ArticleSummary | null = null;

if (article) {
  try {
    const encodedCategory = encodeURIComponent(article.category);
    const res = await fetchApi<{ data: ArticleSummary[]; pagination: { totalPages: number } }>(
      `/articles?status=published&category=${encodedCategory}&limit=50`
    );
    const siblings = res.data;
    const idx = siblings.findIndex((a) => a.slug === slug);
    if (idx > 0) nextArticle = siblings[idx - 1]; // 新しい順: idx-1 が「次」
    if (idx >= 0 && idx < siblings.length - 1) prevArticle = siblings[idx + 1]; // 「前」
  } catch {
    // 前後記事取得失敗は無視
  }
}

const canonicalUrl = `${Astro.url.origin}/articles/${slug}`;

// JSON-LD 構造化データ (F-03)
const jsonLd = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: article.title,
      description: article.excerpt,
      author: { '@type': 'Person', name: article.author },
      datePublished: article.publishedAt ?? article.createdAt,
      dateModified: article.publishedAt ?? article.createdAt,
      url: canonicalUrl,
      publisher: {
        '@type': 'Organization',
        name: 'ttoStudio',
        url: Astro.url.origin,
      },
      keywords: article.tags.join(', '),
      articleSection: article.category,
    }
  : null;
---

<BaseLayout
  title={article?.title ?? '記事'}
  description={article?.excerpt}
  ogTitle={article ? `${article.title} — AI Tech Blog` : undefined}
  ogDescription={article?.excerpt}
  ogType="article"
  canonicalUrl={canonicalUrl}
>
  <Fragment slot="head">
    {/* JSON-LD 構造化データ (F-03) */}
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    {/* シンタックスハイライト (F-05) */}
    <link id="hljs-dark" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/github-dark.min.css" />
    <link id="hljs-light" rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/github.min.css" disabled />
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>
  </Fragment>

  {article && (
    <div class="article-layout">
      <article class="article-detail">
        <header class="article-header">
          <div class="meta">
            <a href={`/category/${article.category}`} class="category-badge">{article.category}</a>
            {dateStr && <time>{dateStr}</time>}
            <span class="reading-time">{readingTime}分で読めます</span>
          </div>
          <h1 class="article-title">{article.title}</h1>
          <div class="author-row">
            <span class="author-avatar">{article.author.charAt(0).toUpperCase()}</span>
            <div class="author-details">
              <span class="author-name">{article.author}</span>
              {dateStr && <span class="publish-date">{dateStr} に公開</span>}
            </div>
          </div>
          {article.tags.length > 0 && (
            <div class="tags">
              {article.tags.map((tag) => <span class="tag">#{tag}</span>)}
            </div>
          )}
        </header>

        <div class="content" set:html={htmlContent} />

        {/* 前後記事ナビゲーション (F-08) */}
        {(prevArticle || nextArticle) && (
          <nav class="article-nav" aria-label="前後記事">
            <div class="article-nav-inner">
              {prevArticle ? (
                <a href={`/articles/${prevArticle.slug}`} class="nav-link nav-prev">
                  <span class="nav-label">&larr; 前の記事</span>
                  <span class="nav-title">{prevArticle.title}</span>
                </a>
              ) : <div />}
              {nextArticle ? (
                <a href={`/articles/${nextArticle.slug}`} class="nav-link nav-next">
                  <span class="nav-label">次の記事 &rarr;</span>
                  <span class="nav-title">{nextArticle.title}</span>
                </a>
              ) : <div />}
            </div>
          </nav>
        )}

        <footer class="article-footer">
          <a href="/" class="back-link">&larr; 記事一覧に戻る</a>
        </footer>
      </article>

      {/* 目次サイドバー (F-04): 1200px超でのみ表示 */}
      <aside class="toc-sidebar">
        <TableOfContents headings={headings} />
      </aside>
    </div>
  )}
</BaseLayout>

<!-- Mermaid & Highlight.js & Copy buttons -->
<script>
  // テーマに応じて highlight.js の CSS を切り替え (F-05)
  function applyHljsTheme() {
    const theme = document.documentElement.getAttribute('data-theme');
    const dark = document.getElementById('hljs-dark') as HTMLLinkElement | null;
    const light = document.getElementById('hljs-light') as HTMLLinkElement | null;
    if (theme === 'light') {
      if (dark) dark.disabled = true;
      if (light) light.disabled = false;
    } else {
      if (dark) dark.disabled = false;
      if (light) light.disabled = true;
    }
  }

  applyHljsTheme();
  const themeObserver = new MutationObserver(applyHljsTheme);
  themeObserver.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
  });

  // Mermaid レンダリング
  async function renderMermaid() {
    const codeBlocks = document.querySelectorAll('pre code.language-mermaid');
    if (codeBlocks.length === 0) return;

    const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
    const theme = document.documentElement.getAttribute('data-theme') === 'light' ? 'default' : 'dark';
    mermaid.initialize({ startOnLoad: false, theme, securityLevel: 'strict' });

    for (const block of codeBlocks) {
      const pre = block.parentElement;
      if (!pre) continue;
      const container = document.createElement('div');
      container.className = 'mermaid';
      container.textContent = block.textContent ?? '';
      pre.replaceWith(container);
    }

    await mermaid.run({ querySelector: '.mermaid' });
  }

  // コードブロックにコピーボタン追加
  function addCopyButtons() {
    const codeBlocks = document.querySelectorAll('.content pre');
    for (const block of codeBlocks) {
      if (block.querySelector('.copy-btn')) continue;
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.textContent = 'コピー';
      btn.addEventListener('click', async () => {
        const code = block.querySelector('code');
        if (code) {
          await navigator.clipboard.writeText(code.textContent ?? '');
          btn.textContent = 'コピー済み!';
          setTimeout(() => { btn.textContent = 'コピー'; }, 2000);
        }
      });
      (block as HTMLElement).style.position = 'relative';
      block.appendChild(btn);
    }
  }

  // 初期化: Mermaid → hljs → コピーボタン の順で実行
  async function init() {
    await renderMermaid();

    // highlight.js でコードブロックをハイライト（mermaid以外）
    if (typeof (window as any).hljs !== 'undefined') {
      document.querySelectorAll('.content pre code:not(.language-mermaid)').forEach((block) => {
        (window as any).hljs.highlightElement(block);
      });
    }

    addCopyButtons();
  }

  init();
</script>

<style>
  /* 記事ページ全体レイアウト: 1200px超でサイドバーTOC表示 (F-04) */
  .article-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  .toc-sidebar {
    display: none;
  }

  @media (min-width: 1200px) {
    .article-layout {
      grid-template-columns: 1fr 260px;
      max-width: calc(var(--max-width-article) + 260px + 2rem);
      margin: 0 auto;
    }

    .toc-sidebar {
      display: block;
    }
  }

  .article-detail {
    min-width: 0;
    max-width: var(--max-width-article);
  }

  /* Header */
  .article-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    flex-wrap: wrap;
  }

  .reading-time {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .category-badge {
    background: var(--color-badge-bg);
    color: var(--color-badge-text);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.75rem;
    text-decoration: none;
  }

  .category-badge:hover {
    text-decoration: none;
    opacity: 0.8;
  }

  .article-title {
    font-size: 2.25rem;
    font-weight: 900;
    line-height: 1.3;
    margin-bottom: 1.25rem;
    background: linear-gradient(135deg, var(--color-gradient-start), var(--color-gradient-end));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .author-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .author-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-gradient-start), var(--color-gradient-end));
    color: #fff;
    font-size: 0.9rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .author-details {
    display: flex;
    flex-direction: column;
  }

  .author-name {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .publish-date {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8rem;
    color: var(--color-accent);
    background: var(--color-badge-bg);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
  }

  /* Article Content */
  .content {
    font-size: 1.125rem;
    line-height: 1.8;
  }

  .content :global(h2) {
    font-size: 1.6rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
    background: linear-gradient(135deg, var(--color-gradient-start), var(--color-gradient-end));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .content :global(h3) {
    font-size: 1.3rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
    color: var(--color-accent);
  }

  .content :global(h4) {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
  }

  .content :global(p) {
    margin: 1.25rem 0;
  }

  .content :global(ul), .content :global(ol) {
    margin: 1.25rem 0;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin: 0.35rem 0;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-text-secondary);
    background: var(--color-bg-tertiary);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin: 1.5rem 0;
  }

  .content :global(pre) {
    background: var(--color-code-bg);
    padding: 1.25rem;
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin: 1.5rem 0;
    border: 1px solid var(--color-border);
    font-size: 0.875rem;
  }

  .content :global(.copy-btn) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: var(--color-bg-tertiary);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: background-color 0.2s ease, color 0.2s ease;
    z-index: 1;
  }

  .content :global(.copy-btn:hover) {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }

  .content :global(.mermaid) {
    text-align: center;
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: rgba(34, 211, 238, 0.3);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.2s ease;
  }

  .content :global(a:hover) {
    text-decoration-color: var(--color-accent);
  }

  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .content :global(th),
  .content :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .content :global(th) {
    background: var(--color-bg-tertiary);
    font-weight: 600;
  }

  /* 前後記事ナビゲーション (F-08) */
  .article-nav {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .article-nav-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem 1.25rem;
    background: var(--color-card-bg);
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .nav-link:hover {
    border-color: rgba(34, 211, 238, 0.3);
    background: var(--color-bg-tertiary);
    text-decoration: none;
  }

  .nav-next {
    text-align: right;
  }

  .nav-label {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .nav-title {
    font-size: 0.9rem;
    color: var(--color-text);
    font-weight: 600;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Footer */
  .article-footer {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .article-title {
      font-size: 1.75rem;
    }

    .content {
      font-size: 1rem;
    }

    .content :global(h2) {
      font-size: 1.35rem;
    }

    .content :global(h3) {
      font-size: 1.15rem;
    }

    .article-nav-inner {
      grid-template-columns: 1fr;
    }

    .nav-next {
      text-align: left;
    }
  }
</style>
