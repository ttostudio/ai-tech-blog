---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchApi } from '../../lib/api';
import { marked } from 'marked';

interface ArticleData {
  id: string;
  title: string;
  slug: string;
  content: string;
  excerpt: string;
  category: string;
  tags: string[];
  author: string;
  status: string;
  publishedAt: string | null;
  createdAt: string;
  thumbnailUrl?: string | null;
}

const { slug } = Astro.params;
let article: ArticleData | null = null;

try {
  const res = await fetchApi<{ data: ArticleData }>(`/articles/${slug}`);
  article = res.data;
} catch {
  return Astro.redirect('/404');
}

/** HTMLサニタイズ: scriptタグ、イベントハンドラ、危険な属性を除去 */
function sanitizeHtml(html: string): string {
  return html
    .replace(/<script\b[^<]*(?:(?!<\/script>)<[^<]*)*<\/script>/gi, '')
    .replace(/<iframe\b[^>]*>.*?<\/iframe>/gi, '')
    .replace(/<object\b[^>]*>.*?<\/object>/gi, '')
    .replace(/<embed\b[^>]*\/?>/gi, '')
    .replace(/<link\b[^>]*\/?>/gi, '')
    .replace(/\bon\w+\s*=\s*(?:"[^"]*"|'[^']*'|[^\s>]*)/gi, '')
    .replace(/javascript\s*:/gi, 'blocked:')
    .replace(/data\s*:\s*text\/html/gi, 'blocked:');
}

const rawHtml = article ? await marked.parse(article.content) : '';
const htmlContent = sanitizeHtml(rawHtml);
const dateStr = article?.publishedAt
  ? new Date(article.publishedAt).toLocaleDateString('ja-JP', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';

const CATEGORY_GRADIENTS: Record<string, string> = {
  'claude-code': 'linear-gradient(135deg, #667eea, #764ba2)',
  'ai-hacks': 'linear-gradient(135deg, #f093fb, #f5576c)',
  'ai-news': 'linear-gradient(135deg, #4facfe, #00f2fe)',
  'tech': 'linear-gradient(135deg, #43e97b, #38f9d7)',
};
const fallbackGradient = article ? (CATEGORY_GRADIENTS[article.category] ?? CATEGORY_GRADIENTS['claude-code']) : '';
const ogImage = article?.thumbnailUrl ?? '/og-default.png';
---

<BaseLayout title={article?.title ?? '記事'} description={article?.excerpt} ogImage={ogImage}>
  {article && (
    <article class="article-detail">
      <header>
        {article.thumbnailUrl ? (
          <div class="eyecatch-wrapper">
            <img
              src={article.thumbnailUrl}
              alt={article.title}
              width="1024"
              height="576"
              class="eyecatch"
              decoding="async"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
            />
            <div class="eyecatch-fallback" style={`background: ${fallbackGradient}`}>
              <span class="eyecatch-fallback-label">{article.category}</span>
            </div>
          </div>
        ) : (
          <div class="eyecatch-wrapper">
            <div class="eyecatch-fallback visible" style={`background: ${fallbackGradient}`}>
              <span class="eyecatch-fallback-label">{article.category}</span>
            </div>
          </div>
        )}
        <div class="meta">
          <a href={`/category/${article.category}`} class="category">{article.category}</a>
          <span class="author">著者: {article.author}</span>
          {dateStr && <time>{dateStr}</time>}
        </div>
        <h1>{article.title}</h1>
        {article.tags.length > 0 && (
          <div class="tags">
            {article.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        )}
      </header>

      <div class="content" set:html={htmlContent} />
    </article>
  )}
</BaseLayout>

<!-- Mermaid: クライアントサイドで ```mermaid コードブロックを図にレンダリング -->
<script>
  async function renderMermaid() {
    const codeBlocks = document.querySelectorAll('pre code.language-mermaid');
    if (codeBlocks.length === 0) return;

    const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
    mermaid.initialize({
      startOnLoad: false,
      theme: window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'default',
      securityLevel: 'strict',
    });

    for (const block of codeBlocks) {
      const pre = block.parentElement;
      if (!pre) continue;
      const container = document.createElement('div');
      container.className = 'mermaid';
      container.textContent = block.textContent ?? '';
      pre.replaceWith(container);
    }

    await mermaid.run({ querySelector: '.mermaid' });
  }

  renderMermaid();
</script>

<style>
  .eyecatch-wrapper {
    margin-bottom: 1.5rem;
    border-radius: var(--thumbnail-radius);
    overflow: hidden;
    aspect-ratio: var(--thumbnail-ratio);
  }

  .eyecatch {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: var(--thumbnail-radius);
  }

  .eyecatch-fallback {
    display: none;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    border-radius: var(--thumbnail-radius);
  }

  .eyecatch-fallback.visible {
    display: flex;
  }

  .eyecatch-fallback-label {
    color: #fff;
    font-weight: 700;
    font-size: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
  }

  .article-detail header {
    margin-bottom: 2rem;
  }

  .meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .category {
    background: var(--color-bg-secondary);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  .author {
    font-style: italic;
  }

  h1 {
    font-size: 2rem;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8rem;
    color: var(--color-accent);
    background: var(--color-bg-secondary);
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
  }

  .content {
    line-height: 1.8;
  }

  .content :global(h2) {
    font-size: 1.5rem;
    margin: 2rem 0 1rem;
  }

  .content :global(h3) {
    font-size: 1.25rem;
    margin: 1.5rem 0 0.75rem;
  }

  .content :global(p) {
    margin: 1rem 0;
  }

  .content :global(ul), .content :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin: 0.25rem 0;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-text-secondary);
  }

  .content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1rem 0;
  }

  .content :global(pre) {
    background: var(--color-bg-secondary);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1rem 0;
  }

  .content :global(.mermaid) {
    text-align: center;
    margin: 1.5rem 0;
    padding: 1rem;
    background: var(--color-bg-secondary);
    border-radius: 8px;
  }
</style>
