---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchApi } from '../../lib/api';
import { marked } from 'marked';

interface ArticleData {
  id: string;
  title: string;
  slug: string;
  content: string;
  excerpt: string;
  category: string;
  tags: string[];
  author: string;
  status: string;
  publishedAt: string | null;
  createdAt: string;
}

const { slug } = Astro.params;
let article: ArticleData | null = null;

try {
  const res = await fetchApi<{ data: ArticleData }>(`/articles/${slug}`);
  article = res.data;
} catch {
  return Astro.redirect('/404');
}

const htmlContent = article ? await marked.parse(article.content) : '';
const dateStr = article?.publishedAt
  ? new Date(article.publishedAt).toLocaleDateString('ja-JP', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';
---

<BaseLayout title={article?.title ?? 'Article'} description={article?.excerpt}>
  {article && (
    <article class="article-detail">
      <header>
        <div class="meta">
          <a href={`/category/${article.category}`} class="category">{article.category}</a>
          <span class="author">by {article.author}</span>
          {dateStr && <time>{dateStr}</time>}
        </div>
        <h1>{article.title}</h1>
        {article.tags.length > 0 && (
          <div class="tags">
            {article.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        )}
      </header>

      <div class="content" set:html={htmlContent} />
    </article>
  )}
</BaseLayout>

<style>
  .article-detail header {
    margin-bottom: 2rem;
  }

  .meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .category {
    background: var(--color-bg-secondary);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  .author {
    font-style: italic;
  }

  h1 {
    font-size: 2rem;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8rem;
    color: var(--color-accent);
    background: var(--color-bg-secondary);
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
  }

  .content {
    line-height: 1.8;
  }

  .content :global(h2) {
    font-size: 1.5rem;
    margin: 2rem 0 1rem;
  }

  .content :global(h3) {
    font-size: 1.25rem;
    margin: 1.5rem 0 0.75rem;
  }

  .content :global(p) {
    margin: 1rem 0;
  }

  .content :global(ul), .content :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin: 0.25rem 0;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-text-secondary);
  }

  .content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1rem 0;
  }

  .content :global(pre) {
    background: var(--color-bg-secondary);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1rem 0;
  }
</style>
