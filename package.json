{
  "name": "ai-tech-blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Automatically generates blog articles from AI news collected by ttoClaw",
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx,astro}'",
    "pretest": "npm run build --workspace=packages/shared",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:backend": "npm run dev --workspace=packages/backend",
    "dev:frontend": "npm run dev --workspace=packages/frontend"
  },
  "devDependencies": {
    "@eslint/js": "9.23.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "25.5.0",
    "eslint": "^9.39.4",
    "typescript": "5.8.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "3.0.9"
  },
  "engines": {
    "node": ">=22"
  }
}
